# Optional: URL of the stellar-txwatch-core API
# Leave empty to use localStorage-only mode
# Examples:
#   Local development: http://localhost:8000
#   Staging: https://api-staging.example.com
#   Production: https://api.example.com
NEXT_PUBLIC_API_URL=

# Optional: Webhook testing endpoint
# Use this to test webhook delivery locally
# Example: http://localhost:3001/webhooks
# WEBHOOK_TEST_URL=

# Optional: Soroban RPC endpoint override
# Defaults to official Stellar endpoints if not set
# Example: https://soroban-testnet.stellar.org
# NEXT_PUBLIC_SOROBAN_RPC_URL=

# Optional: Horizon API endpoint override
# Defaults to official Stellar endpoints if not set
# Example: https://horizon-testnet.stellar.org
# NEXT_PUBLIC_HORIZON_URL=
